build = "cd ai-dashboard/backend && python3 -m pip install -r requirements.txt --index-url https://pypi.org/simple/"
run = "cd ai-dashboard/backend && python3 -m uvicorn main:app --host 0.0.0.0 --port 8000"

[deployment]
build = "cd ai-dashboard/backend && python3 -m pip install -r requirements.txt --index-url https://pypi.org/simple/"
run = "cd ai-dashboard/backend && python3 -m uvicorn main:app --host 0.0.0.0 --port 8000"
